# =============================================================================
# Codver Server Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
API_KEY_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=3000
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_PATH=./data/codver.db

# -----------------------------------------------------------------------------
# Job Execution
# -----------------------------------------------------------------------------
# CODVER_DEV_DIR=~/.codver-dev
# MAX_CONCURRENT_JOBS=3
# JOB_RETENTION_DAYS=7
# DEFAULT_CPU_LIMIT=2
# DEFAULT_MEMORY_LIMIT=4g
# DEFAULT_JOB_TIMEOUT_MS=1800000
# MAX_RETRY_COUNT=2
# RETRY_BASE_DELAY_MS=5000
# CLEANUP_ON_COMPLETE=true
# CLEANUP_IMAGES_ON_COMPLETE=false
# DEFAULT_PR_AUTHOR=bot

# -----------------------------------------------------------------------------
# GitHub / Git
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxx
# GIT_USER_NAME=Codver Bot
# GIT_USER_EMAIL=codver-bot@codver.dev

# -----------------------------------------------------------------------------
# AI Agent Defaults
# -----------------------------------------------------------------------------
# DEFAULT_MODEL=
# DEFAULT_PROVIDER=
# DEFAULT_THINKING_LEVEL=

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
# WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://example.com

# -----------------------------------------------------------------------------
# AI Provider API Keys (any *_API_KEY env var is auto-forwarded to containers)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
