# ─── Codver Base Dockerfile ───────────────────────────────────────────
#
# This Dockerfile installs the proto toolchain (moonrepo/proto) and uses it
# to provision common development tools. It is intended to be pre-built
# and cached as a base image for codver dev environments.
#
# The LLM will create a project-specific Dockerfile that extends this one,
# adding only the extra dependencies the client project needs.
#
# Proto is installed via the official install script:
#   https://moonrepo.dev/docs/proto/install
#
# Build:
#   docker build -t codver-base -f docker/Dockerfile.base docker/
#
# Usage in compose:
#   The LLM-modified compose file will reference this image for the pi-agent
#   service and may add project-specific services alongside it.
# ─────────────────────────────────────────────────────────────────────

FROM debian:bookworm-slim AS proto-setup

# Install OS packages required by proto and its provisioned tools.
# Per https://moonrepo.dev/docs/proto/install: git, tar, unzip, gzip, xz.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        gzip \
        unzip \
        xz-utils \
    && rm -rf /var/lib/apt/lists/*

# ─── Install proto ──────────────────────────────────────────────────
# PROTO_HOME is set to /opt/proto so tool installs are deterministic
# and independent of the user's $HOME (default: ~/.proto).
# --no-profile : skip shell profile modifications (not needed in Docker)
# --yes        : non-interactive install (no prompts)
ENV PROTO_HOME=/opt/proto
ENV PATH="${PROTO_HOME}/shims:${PROTO_HOME}/bin:${PATH}"

ARG PROTO_VERSION=0.57.2
RUN curl -fsSL https://moonrepo.dev/install/proto.sh \
    | bash -s -- "${PROTO_VERSION}" --yes --no-profile

# ─── Tool installation ─────────────────────────────────────────────
# Proto reads .prototools and installs pinned versions of each tool.
# The .prototools.base file provides a baseline; project-specific
# Dockerfiles can override or extend it.
COPY .prototools.base ${PROTO_HOME}/.prototools

WORKDIR ${PROTO_HOME}

RUN proto install --yes

# ─── Final stage ───────────────────────────────────────────────────
FROM debian:bookworm-slim

# Copy the full proto toolchain (proto binary + all provisioned tools)
ENV PROTO_HOME=/opt/proto
ENV PATH="${PROTO_HOME}/shims:${PROTO_HOME}/bin:/root/.bun/bin:${PATH}"
COPY --from=proto-setup ${PROTO_HOME} ${PROTO_HOME}

# Install runtime dependencies (git for cloning, ca-certificates for HTTPS)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# install Pi agent
RUN bun add -g --ignore-scripts @earendil-works/pi-coding-agent

# Default command -> keep running so the container doesn't exit immediately. The agent will be started
CMD ["tail", "-f", "/dev/null"]
