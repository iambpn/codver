#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_DIR="$(dirname "$SCRIPT_DIR")"

# ── load_path ────────────────────────────────────────────────────────────
# Source ~/.bashrc with the interactive guard stripped, then emit export
# statements so the caller can eval them into the current shell:
#
#   eval "$(~/.codver/bin/codver load_path)"
#
# PATH is never displayed to the user — eval consumes it inside the SSH session.
if [ "${1:-}" = "load_path" ]; then
  if [ -f "$HOME/.bashrc" ]; then
    filtered=$(awk '
      /^[[:space:]]*case[[:space:]]+\$-/ { in_guard=1; next }
      /^[[:space:]]*esac/ && in_guard   { in_guard=0; next }
      !in_guard
    ' "$HOME/.bashrc")
    eval "$filtered" 2>/dev/null
  fi
  printf 'export PATH="%s"\n' "$PATH"
  exit 0
fi

exec bun run "$SERVER_DIR/codver.ts" "$@"
